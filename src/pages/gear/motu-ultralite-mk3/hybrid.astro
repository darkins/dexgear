---
import MainLayout from '../../../layouts/MainLayout.astro';
import MotuSidebar from '../../../components/MotuSidebar.astro';
const title = "Hybrid FireWire/USB2";
---
<MainLayout title={title}>
  <div class="flex gap-8 items-start">
    <div class="w-[250px] flex-shrink-0">
      <MotuSidebar />
    </div>
    <article class="prose max-w-none">
      <h1>{title}</h1>
      <p>Source: <a href="https://motu.com/products/motuaudio/ultralite-mk3/hybrid.html" target="_blank" rel="noopener">MOTU product page</a></p>
      <p>The UltraLite-mk3 supports hybrid host connectivity modes that enable both legacy and modern systems to connect with low latency and flexible routing. Users can switch modes in software to choose the best interface protocol for their setup.</p>
      <figure>
        <img src="/assets/motu/ultralite-mk3/hybrid.jpg" alt="Hybrid FireWire/USB2" />
        <figcaption>Absolute asset path: C:\\www\\dexgear\\public\\assets\\motu\\ultralite-mk3\\hybrid.jpg</figcaption>
      </figure>
    </article>
  </div>
</MainLayout>

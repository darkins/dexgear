---
import MainLayout from '../../../layouts/MainLayout.astro';
import MotuSidebar from '../../../components/MotuSidebar.astro';
const title = "Tuner & Analysis Tools";
---
<MainLayout title={title}>
  <div class="flex gap-8 items-start">
    <div class="w-[250px] flex-shrink-0">
      <MotuSidebar />
    </div>
    <article class="prose max-w-none">
      <h1>{title}</h1>
      <p>Source: <a href="https://motu.com/products/motuaudio/ultralite-mk3/cuemix-fx-overview.html" target="_blank" rel="noopener">MOTU product page</a></p>
      <p>CueMix FX includes tuner and metering tools that help with tuning instruments and analyzing signal levels. These utilities are integrated into the software for quick access during setup and tracking.</p>
      <figure>
        <img src="/assets/motu/ultralite-mk3/tuner-analysis.jpg" alt="Tuner and analysis tools" />
        <figcaption>Absolute asset path: C:\\www\\dexgear\\public\\assets\\motu\\ultralite-mk3\\tuner-analysis.jpg</figcaption>
      </figure>
    </article>
  </div>
</MainLayout>

---
import MainLayout from '../../../layouts/MainLayout.astro';
import MotuSidebar from '../../../components/MotuSidebar.astro';
const title = "Comprehensive I/O";
---
<MainLayout title={title}>
  <div class="flex gap-8 items-start">
    <div class="w-[250px] flex-shrink-0">
      <MotuSidebar />
    </div>
    <article class="prose max-w-none">
      <h1>{title}</h1>
      <p>Source: <a href="https://motu.com/products/motuaudio/ultralite-mk3/i-o.html" target="_blank" rel="noopener">MOTU product page</a></p>
      <p>The UltraLite-mk3 delivers a versatile set of inputs and outputs suitable for project and professional studios, offering flexible routing to connect microphones, instruments, monitors, and external processors. Digital and analog I/O options make it easy to integrate with existing rigs.</p>
      <figure>
        <img src="/assets/motu/ultralite-mk3/io.jpg" alt="Comprehensive I/O" />
        <figcaption>Absolute asset path: C:\\www\\dexgear\\public\\assets\\motu\\ultralite-mk3\\io.jpg</figcaption>
      </figure>
    </article>
  </div>
</MainLayout>

const title = "Motu Ultralite-mk3 Hybrid";
const description = "Hybrid audio interface for professional music production.";
const url = "https://motu.com/products/motuaudio/ultralite-mk3";
const tags = ["Audio Interface", "MOTU"];
---

<MainLayout title={title} description={description} url={url} tags={tags}>
  <div class="flex gap-8 items-start">
    <div class="w-[250px] flex-shrink-0">
      <MotuSidebar />
    </div>
    <article class="prose max-w-none">
    <p class="text-sm"><a href={url} target="_blank" rel="noopener noreferrer">MOTU product page</a></p>

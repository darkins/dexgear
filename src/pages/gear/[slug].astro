---
import MainLayout from "../../layouts/MainLayout.astro";
import GearIntro from "../../components/GearIntro.astro";
import { getCollection, getEntry, render } from "astro:content";

export async function getStaticPaths() {
  const gear = await getCollection("gear");
  return gear.map((g) => ({ params: { slug: g.id } }));
}

const { slug } = Astro.params;
const gear = await getEntry("gear", slug!);
if (!gear) throw new Error("Gear not found");

const { Content } = await render(gear);
---

<MainLayout title={gear.data.title} description={gear.data.description}>
  <GearIntro
    title={gear.data.title}
    description={gear.data.description}
    url={gear.data.url}
  />
  <article class="prose mt-8">
    <Content />
  </article>
</MainLayout>

---
import MainLayout from "../../layouts/MainLayout.astro";
import { getCollection, getEntry, render } from "astro:content";

export async function getStaticPaths() {
  const gear = await getCollection("gear");
  return gear.map((g) => ({ params: { slug: g.id } }));
}

const { slug } = Astro.params;
const gear = await getEntry("gear", slug!);
if (!gear) throw new Error("Gear not found");

const { Content } = await render(gear);
---

<MainLayout title={gear.data.title} description={gear.data.description}>
  <section class="content-intro">
    <div>
      <p class="eyebrow">Gear Profile</p>
      <h1>{gear.data.title}</h1>
      <p class="content-intro__lede">{gear.data.description}</p>
    </div>
    <div class="content-intro__actions">
      {
        gear.data.url && (
          <a
            href={gear.data.url}
            class="button-primary"
            target="_blank"
            rel="noopener"
          >
            Official Site
          </a>
        )
      }
      <a href="/" class="button-secondary">Back to Library</a>
    </div>
  </section>
  <article class="prose mt-8">
    <Content />
  </article>
</MainLayout>

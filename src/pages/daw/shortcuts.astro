<MainLayout title="Shortcuts" description="Ableton keyboard shortcuts and productivity references for faster DAW navigation.">
  <section class="content-intro">
    <div>
      <p class="eyebrow">Ableton Workflow</p>
      <h1>Ableton Keyboard Shortcuts</h1>
      <p class="content-intro__lede">A longer-form shortcut reference, now presented in the same reading shell as the rest of the redesigned site.</p>
    </div>
    <div class="content-intro__actions">
      <a
        href="https://www.ableton.com/en/manual/live-keyboard-shortcuts"
        class="button-primary"
        target="_blank"
        rel="noopener"
      >
        Official Ableton Manual
      </a>
      <a href="/daw/m4l" class="button-secondary">Open M4L</a>
    </div>
  </section>
  <article class="prose prose-invert">

      <!-- Sections (paraphrased Windows-only shortcuts) -->

      <h3 id="showing-and-hiding-views" class="mt-6">Showing and Hiding Views</h3>
      <table class="dg-table table-auto w-full text-sm border-collapse mb-6">
        <thead class="text-left text-white"><tr><th class="px-3 py-2">Action</th><th class="px-3 py-2">Windows</th></tr></thead>
        <tbody class="divide-y">
          <tr class="bg-neutral-900 text-neutral-100"><td class="px-3 py-2">Toggle full screen mode</td><td class="px-3 py-2">F11</td></tr>
          <tr class="bg-neutral-800 text-neutral-100"><td class="px-3 py-2">Toggle second window</td><td class="px-3 py-2">Ctrl+Shift+W</td></tr>
          <tr class="bg-neutral-900 text-neutral-100"><td class="px-3 py-2">Toggle Session / Arrangement view</td><td class="px-3 py-2">Tab</td></tr>
          <tr class="bg-neutral-800 text-neutral-100"><td class="px-3 py-2">Toggle between Device / Clip view</td><td class="px-3 py-2">Shift+Tab or F12</td></tr>
          <tr class="bg-neutral-900 text-neutral-100"><td class="px-3 py-2">Toggle Hot-Swap mode</td><td class="px-3 py-2">Q</td></tr>
          <tr class="bg-neutral-800 text-neutral-100"><td class="px-3 py-2">Toggle Drum Rack / last selected pad</td><td class="px-3 py-2">D</td></tr>
          <tr class="bg-neutral-900 text-neutral-100"><td class="px-3 py-2">Hide / Show Info View</td><td class="px-3 py-2">Shift+?</td></tr>
          <tr class="bg-neutral-800 text-neutral-100"><td class="px-3 py-2">Hide / Show Video Window</td><td class="px-3 py-2">Ctrl+Alt+V</td></tr>
          <tr class="bg-neutral-900 text-neutral-100"><td class="px-3 py-2">Hide / Show Browser</td><td class="px-3 py-2">Ctrl+Alt+B or Ctrl+Alt+5</td></tr>
          <tr class="bg-neutral-800 text-neutral-100"><td class="px-3 py-2">Hide / Show Overview</td><td class="px-3 py-2">Ctrl+Alt+O</td></tr>
          <tr class="bg-neutral-900 text-neutral-100"><td class="px-3 py-2">Hide / Show In / Out</td><td class="px-3 py-2">Ctrl+Alt+I</td></tr>
          <tr class="bg-neutral-800 text-neutral-100"><td class="px-3 py-2">Hide / Show Sends</td><td class="px-3 py-2">Ctrl+Alt+S</td></tr>
          <tr class="bg-neutral-900 text-neutral-100"><td class="px-3 py-2">Hide / Show Mixer</td><td class="px-3 py-2">Ctrl+Alt+M</td></tr>
          <tr class="bg-neutral-800 text-neutral-100"><td class="px-3 py-2">Hide / Show Clip View</td><td class="px-3 py-2">Ctrl+Alt+3</td></tr>
          <tr class="bg-neutral-900 text-neutral-100"><td class="px-3 py-2">Hide / Show Device View</td><td class="px-3 py-2">Ctrl+Alt+4</td></tr>
          <tr class="bg-neutral-800 text-neutral-100"><td class="px-3 py-2">Hide / Show the Groove Pool</td><td class="px-3 py-2">Ctrl+Alt+6</td></tr>
          <tr class="bg-neutral-900 text-neutral-100"><td class="px-3 py-2">Open the Settings</td><td class="px-3 py-2">Ctrl+,</td></tr>
          <tr class="bg-neutral-800 text-neutral-100"><td class="px-3 py-2">Close window / dialog</td><td class="px-3 py-2">Esc</td></tr>
        </tbody>
      </table>

      <h3 id="keyboard-focus-and-navigation">Keyboard Focus and Navigation</h3>
      <table class="table-auto w-full text-sm border-collapse mb-6">
        <thead class="dg-table text-left text-white"><tr><th class="px-3 py-2">Action</th><th class="px-3 py-2">Key</th></tr></thead>
        <tbody class="divide-y">
          <tr class="bg-neutral-900 text-neutral-100"><td class="px-3 py-2">Move focus to the Control Bar</td><td class="px-3 py-2">Alt+0</td></tr>
          <tr class="bg-neutral-800 text-neutral-100"><td class="px-3 py-2">Move focus to the Session View</td><td class="px-3 py-2">Alt+1</td></tr>
          <tr class="bg-neutral-900 text-neutral-100"><td class="px-3 py-2">Move focus to the Arrangement View</td><td class="px-3 py-2">Alt+2</td></tr>
          <tr class="bg-neutral-800 text-neutral-100"><td class="px-3 py-2">Move focus to the Clip View</td><td class="px-3 py-2">Alt+3</td></tr>
          <tr class="bg-neutral-900 text-neutral-100"><td class="px-3 py-2">Move focus to the Device View</td><td class="px-3 py-2">Alt+4</td></tr>
          <tr class="bg-neutral-800 text-neutral-100"><td class="px-3 py-2">Move focus to the Browser</td><td class="px-3 py-2">Alt+5</td></tr>
          <tr class="bg-neutral-900 text-neutral-100"><td class="px-3 py-2">Move focus to the Groove Pool</td><td class="px-3 py-2">Alt+6</td></tr>
          <tr class="bg-neutral-800 text-neutral-100"><td class="px-3 py-2">Move focus to the Help View</td><td class="px-3 py-2">Alt+7</td></tr>
          <tr class="bg-neutral-900 text-neutral-100"><td class="px-3 py-2">Move focus to the Selected Clip Panel</td><td class="px-3 py-2">Alt+8</td></tr>
          <tr class="bg-neutral-800 text-neutral-100"><td class="px-3 py-2">Move focus to the Clip Panels</td><td class="px-3 py-2">Alt+Shift+P</td></tr>
        </tbody>
      </table>

      <p class="text-sm text-neutral-300 mb-2">The following shortcuts are available when the <em>Use Tab to Move Focus</em> command is enabled:</p>
      <table class="table-auto w-full text-sm border-collapse mb-6">
        <thead class="dg-table text-left text-white"><tr><th class="px-3 py-2">Action</th><th class="px-3 py-2">Key</th></tr></thead>
        <tbody class="divide-y">
          <tr class="bg-neutral-900 text-neutral-100"><td class="px-3 py-2">Move to next focusable control</td><td class="px-3 py-2">Tab</td></tr>
          <tr class="bg-neutral-800 text-neutral-100"><td class="px-3 py-2">Move to previous focusable control</td><td class="px-3 py-2">Shift+Tab</td></tr>
          <tr class="bg-neutral-900 text-neutral-100"><td class="px-3 py-2">Move to next neighbor of current control (same row)</td><td class="px-3 py-2">Ctrl+Tab</td></tr>
          <tr class="bg-neutral-800 text-neutral-100"><td class="px-3 py-2">Move to previous neighbor of current control (same row)</td><td class="px-3 py-2">Ctrl+Shift+Tab</td></tr>
        </tbody>
      </table>

      <h3 id="working-with-sets-and-the-program">Working with Sets and the Program</h3>
      <table class="table-auto w-full text-sm border-collapse mb-6">
        <thead class="dg-table text-left text-white"><tr><th class="px-3 py-2">Action</th><th class="px-3 py-2">Key</th></tr></thead>
        <tbody class="divide-y">
          <tr class="bg-neutral-900 text-neutral-100"><td class="px-3 py-2">New Live Set</td><td class="px-3 py-2">Ctrl+N</td></tr>
          <tr class="bg-neutral-800 text-neutral-100"><td class="px-3 py-2">Open Live Set</td><td class="px-3 py-2">Ctrl+O</td></tr>
          <tr class="bg-neutral-900 text-neutral-100"><td class="px-3 py-2">Save Live Set</td><td class="px-3 py-2">Ctrl+S</td></tr>
          <tr class="bg-neutral-800 text-neutral-100"><td class="px-3 py-2">Save Live Set As…</td><td class="px-3 py-2">Ctrl+Shift+S</td></tr>
          <tr class="bg-neutral-900 text-neutral-100"><td class="px-3 py-2">Quit Live</td><td class="px-3 py-2">Ctrl+Q</td></tr>
          <tr class="bg-neutral-800 text-neutral-100"><td class="px-3 py-2">Export Audio/Video</td><td class="px-3 py-2">Ctrl+Shift+R</td></tr>
        </tbody>
      </table>

      <h3 id="working-with-devices-and-plug-ins">Working with Devices and Plug-Ins</h3>
      <table class="table-auto w-full text-sm border-collapse mb-6">
        <thead class="dg-table text-left text-white"><tr><th class="px-3 py-2">Action</th><th class="px-3 py-2">Key</th></tr></thead>
        <tbody class="divide-y">
          <tr class="bg-neutral-900 text-neutral-100"><td class="px-3 py-2">Group Devices</td><td class="px-3 py-2">Ctrl+G</td></tr>
          <tr class="bg-neutral-800 text-neutral-100"><td class="px-3 py-2">Ungroup Devices</td><td class="px-3 py-2">Ctrl+Shift+G</td></tr>
          <tr class="bg-neutral-900 text-neutral-100"><td class="px-3 py-2">Reset Parameter Value</td><td class="px-3 py-2">Delete or double-click</td></tr>
          <tr class="bg-neutral-800 text-neutral-100"><td class="px-3 py-2">Load Selected Device from Browser</td><td class="px-3 py-2">Enter</td></tr>
          <tr class="bg-neutral-900 text-neutral-100"><td class="px-3 py-2">Hot-Swap Selected Device</td><td class="px-3 py-2">Q</td></tr>
          <tr class="bg-neutral-800 text-neutral-100"><td class="px-3 py-2">Show/Hide Plug-In Window</td><td class="px-3 py-2">Ctrl+Alt+P</td></tr>
        </tbody>
      </table>

      <h3 id="midi-editing">MIDI Editing</h3>
      <p class="text-sm text-neutral-300 mb-3">All shortcuts apply when the MIDI Note Editor has focus and Draw Mode is <em>off</em>, unless noted.</p>

      <h4 class="text-sm font-semibold text-neutral-400 uppercase tracking-wide mt-4 mb-2">Drawing &amp; Input</h4>
      <table class="table-auto w-full text-sm border-collapse mb-4">
        <thead class="dg-table text-left text-white"><tr><th class="px-3 py-2">Action</th><th class="px-3 py-2">Key</th></tr></thead>
        <tbody class="divide-y">
          <tr class="bg-neutral-900 text-neutral-100"><td class="px-3 py-2">Toggle Draw Mode</td><td class="px-3 py-2">B</td></tr>
          <tr class="bg-neutral-800 text-neutral-100"><td class="px-3 py-2">Toggle pitch-lock drawing (when Draw Mode with Pitch Lock is on)</td><td class="px-3 py-2">Alt</td></tr>
          <tr class="bg-neutral-900 text-neutral-100"><td class="px-3 py-2">Delete note (not in Draw Mode)</td><td class="px-3 py-2">Double-click note</td></tr>
          <tr class="bg-neutral-800 text-neutral-100"><td class="px-3 py-2">Deactivate / reactivate selected note(s)</td><td class="px-3 py-2">0</td></tr>
          <tr class="bg-neutral-900 text-neutral-100"><td class="px-3 py-2">Copy notes to new position</td><td class="px-3 py-2">Ctrl+drag</td></tr>
        </tbody>
      </table>

      <h4 class="text-sm font-semibold text-neutral-400 uppercase tracking-wide mt-4 mb-2">Selecting Notes</h4>
      <table class="table-auto w-full text-sm border-collapse mb-4">
        <thead class="dg-table text-left text-white"><tr><th class="px-3 py-2">Action</th><th class="px-3 py-2">Key</th></tr></thead>
        <tbody class="divide-y">
          <tr class="bg-neutral-900 text-neutral-100"><td class="px-3 py-2">Select all notes</td><td class="px-3 py-2">Ctrl+A</td></tr>
          <tr class="bg-neutral-800 text-neutral-100"><td class="px-3 py-2">Deselect all / collapse selection</td><td class="px-3 py-2">Esc</td></tr>
          <tr class="bg-neutral-900 text-neutral-100"><td class="px-3 py-2">Toggle between timespan and enclosed notes</td><td class="px-3 py-2">Enter</td></tr>
          <tr class="bg-neutral-800 text-neutral-100"><td class="px-3 py-2">Select note nearest insert marker</td><td class="px-3 py-2">Ctrl+Up / Ctrl+Down</td></tr>
          <tr class="bg-neutral-900 text-neutral-100"><td class="px-3 py-2">Next / previous note in same key track</td><td class="px-3 py-2">Ctrl+Left / Ctrl+Right</td></tr>
          <tr class="bg-neutral-800 text-neutral-100"><td class="px-3 py-2">Add next / previous note to selection</td><td class="px-3 py-2">Ctrl+Shift+Up / Ctrl+Shift+Down</td></tr>
          <tr class="bg-neutral-900 text-neutral-100"><td class="px-3 py-2">Extend timespan selection by grid</td><td class="px-3 py-2">Shift+Left / Shift+Right</td></tr>
          <tr class="bg-neutral-800 text-neutral-100"><td class="px-3 py-2">Extend selection to note boundary</td><td class="px-3 py-2">Shift+Alt+Left / Shift+Alt+Right</td></tr>
          <tr class="bg-neutral-900 text-neutral-100"><td class="px-3 py-2">Add / remove key track notes to selection</td><td class="px-3 py-2">Shift+click piano key</td></tr>
        </tbody>
      </table>

      <h4 class="text-sm font-semibold text-neutral-400 uppercase tracking-wide mt-4 mb-2">Moving &amp; Transposing</h4>
      <table class="table-auto w-full text-sm border-collapse mb-4">
        <thead class="dg-table text-left text-white"><tr><th class="px-3 py-2">Action</th><th class="px-3 py-2">Key</th></tr></thead>
        <tbody class="divide-y">
          <tr class="bg-neutral-900 text-neutral-100"><td class="px-3 py-2">Move note left / right by grid</td><td class="px-3 py-2">Left / Right arrow</td></tr>
          <tr class="bg-neutral-800 text-neutral-100"><td class="px-3 py-2">Transpose note by semitone</td><td class="px-3 py-2">Up / Down arrow</td></tr>
          <tr class="bg-neutral-900 text-neutral-100"><td class="px-3 py-2">Transpose note by octave</td><td class="px-3 py-2">Shift+Up / Shift+Down</td></tr>
          <tr class="bg-neutral-800 text-neutral-100"><td class="px-3 py-2">Move insert marker to note boundary</td><td class="px-3 py-2">Ctrl+Left / Ctrl+Right (no selection)</td></tr>
          <tr class="bg-neutral-900 text-neutral-100"><td class="px-3 py-2">Move insert marker to start / end of clip</td><td class="px-3 py-2">Home / End</td></tr>
        </tbody>
      </table>

      <h4 class="text-sm font-semibold text-neutral-400 uppercase tracking-wide mt-4 mb-2">Note Length</h4>
      <table class="table-auto w-full text-sm border-collapse mb-4">
        <thead class="dg-table text-left text-white"><tr><th class="px-3 py-2">Action</th><th class="px-3 py-2">Key</th></tr></thead>
        <tbody class="divide-y">
          <tr class="bg-neutral-900 text-neutral-100"><td class="px-3 py-2">Extend / shorten selected note(s) by grid</td><td class="px-3 py-2">Shift+Right / Shift+Left</td></tr>
          <tr class="bg-neutral-800 text-neutral-100"><td class="px-3 py-2">Extend / shorten without grid snap</td><td class="px-3 py-2">Shift+Alt+Right / Shift+Alt+Left</td></tr>
          <tr class="bg-neutral-900 text-neutral-100"><td class="px-3 py-2">Fit notes to time range</td><td class="px-3 py-2">Ctrl+Alt+J</td></tr>
        </tbody>
      </table>

      <h4 class="text-sm font-semibold text-neutral-400 uppercase tracking-wide mt-4 mb-2">Split, Chop &amp; Join</h4>
      <table class="table-auto w-full text-sm border-collapse mb-4">
        <thead class="dg-table text-left text-white"><tr><th class="px-3 py-2">Action</th><th class="px-3 py-2">Key</th></tr></thead>
        <tbody class="divide-y">
          <tr class="bg-neutral-900 text-neutral-100"><td class="px-3 py-2">Freehand split — hold then draw line across notes</td><td class="px-3 py-2">Hold E + drag</td></tr>
          <tr class="bg-neutral-800 text-neutral-100"><td class="px-3 py-2">Split notes at insert marker (no selection) / Chop selected notes on grid</td><td class="px-3 py-2">Ctrl+E</td></tr>
          <tr class="bg-neutral-900 text-neutral-100"><td class="px-3 py-2">Increase / decrease chop parts (while chopping)</td><td class="px-3 py-2">Up / Down arrow</td></tr>
          <tr class="bg-neutral-800 text-neutral-100"><td class="px-3 py-2">Increase / decrease chop parts by power of two</td><td class="px-3 py-2">Shift+Up / Shift+Down (while chopping)</td></tr>
          <tr class="bg-neutral-900 text-neutral-100"><td class="px-3 py-2">Join selected notes of same pitch</td><td class="px-3 py-2">Ctrl+J</td></tr>
        </tbody>
      </table>

      <h4 class="text-sm font-semibold text-neutral-400 uppercase tracking-wide mt-4 mb-2">Quantization</h4>
      <table class="table-auto w-full text-sm border-collapse mb-6">
        <thead class="dg-table text-left text-white"><tr><th class="px-3 py-2">Action</th><th class="px-3 py-2">Key</th></tr></thead>
        <tbody class="divide-y">
          <tr class="bg-neutral-900 text-neutral-100"><td class="px-3 py-2">Quantize selected notes</td><td class="px-3 py-2">Ctrl+U</td></tr>
          <tr class="bg-neutral-800 text-neutral-100"><td class="px-3 py-2">Apply last quantization settings</td><td class="px-3 py-2">Ctrl+Shift+U</td></tr>
        </tbody>
      </table>

      <h3 id="adjusting-values">Adjusting Values</h3>
      <table class="table-auto w-full text-sm border-collapse mb-6">
        <thead class="dg-table text-left text-white"><tr><th class="px-3 py-2">Action</th><th class="px-3 py-2">Key</th></tr></thead>
        <tbody class="divide-y">
          <tr class="bg-neutral-900 text-neutral-100"><td class="px-3 py-2">Decrement/Increment</td><td class="px-3 py-2">Up and Down arrow keys</td></tr>
          <tr class="bg-neutral-800 text-neutral-100"><td class="px-3 py-2">Decrement/Increment in Octaves or Fine Adjustments</td><td class="px-3 py-2">Shift + Up/Down arrow keys</td></tr>
          <tr class="bg-neutral-900 text-neutral-100"><td class="px-3 py-2">Finer Resolution When Dragging</td><td class="px-3 py-2">Shift</td></tr>
          <tr class="bg-neutral-800 text-neutral-100"><td class="px-3 py-2">Return to Default</td><td class="px-3 py-2">Delete</td></tr>
          <tr class="bg-neutral-900 text-neutral-100"><td class="px-3 py-2">Type In Value</td><td class="px-3 py-2">0 … 9</td></tr>
          <tr class="bg-neutral-800 text-neutral-100"><td class="px-3 py-2">Cancel Value Entry</td><td class="px-3 py-2">Esc</td></tr>
          <tr class="bg-neutral-900 text-neutral-100"><td class="px-3 py-2">Confirm Value Entry</td><td class="px-3 py-2">Enter</td></tr>
        </tbody>
      </table>

      <h3 id="commands-for-breakpoint-envelopes">Commands for Breakpoint Envelopes</h3>
      <table class="table-auto w-full text-sm border-collapse mb-6">
        <thead class="dg-table text-left text-white"><tr><th class="px-3 py-2">Action</th><th class="px-3 py-2">Key</th></tr></thead>

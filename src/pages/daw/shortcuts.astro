          <li><a href="#browser" class="text-neutral-300 hover:underline">Browser</a></li>
          <li><a href="#similar-sample-swapping" class="text-neutral-300 hover:underline">Similar Sample Swapping</a></li>
          <li><a href="#key-midi-map-mode" class="text-neutral-300 hover:underline">Key/MIDI Map Mode & Computer MIDI Keyboard</a></li>
          <li><a href="#momentary-latching-shortcuts" class="text-neutral-300 hover:underline">Momentary Latching Shortcuts</a></li>

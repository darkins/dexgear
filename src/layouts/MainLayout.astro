---
import '../styles/global.css';

export let title: string | undefined;


import { getCollection } from 'astro:content';
const gearList = await getCollection('gear');
const labelOverrides: Record<string, string> = {
  'launch-control-xl': 'Novation',
  'ableton': 'DAW',
  'hydrasynth': 'Hydrasynth',
  'block-m': 'Roli',
  'motu-ultralite-mk3': 'Motu',
};

// Desired navigation order (left to right)
const desiredOrder = [
  'ableton',
  'motu-ultralite-mk3',
  'knobbler',
  'hydrasynth',
  'push',
  'block-m',
  'launch-control-xl',
];

const gearBySlug = Object.fromEntries(gearList.map(g => [g.slug, g]));
const navLinks = desiredOrder
  .map(slug => gearBySlug[slug])
  .filter(Boolean)
  .map(g => {
    // Add dropdown children for the DAW (ableton) entry
    if (g.slug === 'ableton') {
      return {
        label: labelOverrides[g.slug] ?? g.data.title,
        children: [
          { href: '/daw/shortcuts', label: 'Shortcuts' },
          { href: '/daw/m4l', label: 'M4L' },
          { href: '/daw/racks', label: 'Racks' },
        ],
      };
    }
    // Add dropdown children for Motu (surface feature pages)
    if (g.slug === 'motu-ultralite-mk3') {
      return {
        label: labelOverrides[g.slug] ?? g.data.title,
        children: [
          { href: '/gear/motu-ultralite-mk3/general-settings', label: 'General Settings' },
          { href: '/gear/motu-ultralite-mk3/cuemix-settings', label: 'Cuemix Settings' },
          { href: '/gear/motu-ultralite-mk3/cuemix', label: 'CueMix' },
          { href: '/gear/motu-ultralite-mk3/connectivity', label: 'Connectivity' },
          { href: '/gear/motu-ultralite-mk3/io', label: 'I/O' },
          { href: '/gear/motu-ultralite-mk3/console', label: 'Console' },
          { href: '/gear/motu-ultralite-mk3/converters', label: 'Converters' },
          { href: '/gear/motu-ultralite-mk3/monitoring', label: 'Monitoring' },
        ],
      };
    }
    return { href: `/gear/${g.slug}`, label: labelOverrides[g.slug] ?? g.data.title };
  });

---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title ? `${title} | Dex-Gear` : 'Dex-Gear'}</title>
    <meta name="description" content="Dex-Gear: Guides, tips, and resources for music gear including Ableton, Motu, Knobbler, Hydrasynth, Push, Block M, and Launch Control XL." />
    <meta property="og:title" content={title ? `${title} | Dex-Gear` : 'Dex-Gear'} />
    <meta property="og:description" content="Dex-Gear: Guides, tips, and resources for music gear." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://dexgear.example.com/" />
    <meta property="og:image" content="/og-image.svg" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title ? `${title} | Dex-Gear` : 'Dex-Gear'} />
    <meta name="twitter:description" content="Dex-Gear: Guides, tips, and resources for music gear." />
    <meta name="twitter:image" content="/og-image.svg" />
    <link rel="canonical" href="https://dexgear.example.com/" />
  </head>
  <body class="theme-neon min-h-screen font-sans">
    <header class="sticky top-0 z-50 bg-gradient-to-r from-fuchsia-700 via-black to-cyan-700 shadow-lg">
      <div class="max-w-7xl mx-auto px-6 md:px-8">
        <div class="flex items-center justify-between h-16">
          <a href="/" class="flex items-center gap-3 no-underline" aria-label="Dex-Gear home">
            <span class="text-2xl md:text-3xl font-extrabold tracking-tight">Dex-Gear</span>
          </a>

          <!-- Desktop nav -->
          <nav aria-label="Main navigation" class="hidden md:block">
            <ul class="flex items-center space-x-6 text-lg font-semibold">
              {navLinks.map(link => (
                link.children ? (
                  <li class="relative group">
                    <button type="button" class="flex items-center gap-2 hover:text-fuchsia-400 transition-colors focus:outline-none" aria-haspopup="true" aria-expanded="false">
                      <span>{link.label}</span>
                      <svg class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 10.94l3.71-3.71a.75.75 0 111.06 1.06l-4.24 4.24a.75.75 0 01-1.06 0L5.21 8.29a.75.75 0 01.02-1.08z" clip-rule="evenodd"/></svg>
                    </button>
                    <div class="absolute left-0 mt-0 w-48 rounded-md shadow-lg opacity-0 group-hover:opacity-100 group-focus-within:opacity-100 transition-opacity pointer-events-none group-hover:pointer-events-auto group-focus-within:pointer-events-auto" style="background: var(--dropdown-bg)">
                      <ul class="py-2 text-sm">
                        {link.children.map(child => (
                          <li><a href={child.href} class="block px-4 py-2 hover:bg-white/5 text-sm">{child.label}</a></li>
                        ))}
                      </ul>
                    </div>
                  </li>
                ) : (
                  <li><a href={link.href} class="hover:text-fuchsia-400 transition-colors" aria-label={link.label}>{link.label}</a></li>
                )
              ))}
            </ul>
          </nav>

          <!-- Mobile hamburger -->
          <div class="md:hidden">
            <button id="menu-btn" aria-label="Toggle navigation" aria-expanded="false" class="p-2 rounded-md hover:bg-white/5 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-fuchsia-400">
              <svg id="icon-open" class="w-6 h-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
              <svg id="icon-close" class="w-6 h-6 hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
          </div>
        </div>
      </div>
      <!-- Mobile menu panel -->
      <div id="mobile-menu" class="md:hidden hidden px-6 pb-4">
        <ul class="flex flex-col gap-3 text-lg font-semibold">
          {navLinks.map(link => (
            link.children ? (
              [
                <li class="px-3 py-2 font-semibold">{link.label}</li>,
                link.children.map(child => (
                  <li><a href={child.href} class="block px-6 py-2 rounded-md hover:bg-white/5">{child.label}</a></li>
                ))
              ]
            ) : (
              <li><a href={link.href} class="block px-3 py-2 rounded-md hover:bg-white/5" aria-label={link.label}>{link.label}</a></li>
            )
          ))}
        </ul>
      </div>
    </header>
    <script type="module">
      document.addEventListener('DOMContentLoaded', () => {
        const btn = document.getElementById('menu-btn');
        const menu = document.getElementById('mobile-menu');
        const openIcon = document.getElementById('icon-open');
        const closeIcon = document.getElementById('icon-close');
        if (!btn || !menu) return;
        btn.addEventListener('click', () => {
          const isHidden = menu.classList.contains('hidden');
          if (isHidden) {
            menu.classList.remove('hidden');
            btn.setAttribute('aria-expanded', 'true');
            openIcon.classList.add('hidden');
            closeIcon.classList.remove('hidden');
          } else {
            menu.classList.add('hidden');
            btn.setAttribute('aria-expanded', 'false');
            openIcon.classList.remove('hidden');
            closeIcon.classList.add('hidden');
          }
        });
      });
    </script>
    <main class="p-8">
      <slot />
    </main>
  </body>
</html>

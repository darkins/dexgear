---
export interface Props {
    id: string;
    title: string;
    description: string;
}

const { id, title, description } = Astro.props;
const youtubeUrl = `https://www.youtube.com/watch?v=${id}`;
const thumbUrl = `https://img.youtube.com/vi/${id}/hqdefault.jpg`;
---

<a
    href={youtubeUrl}
    class="video-card"
    target="_blank"
    rel="noopener noreferrer"
    aria-label={`Watch ${title} on YouTube`}
>
    <div class="video-card__thumb">
        <img
            src={thumbUrl}
            alt={title}
            loading="lazy"
            width="480"
            height="360"
        />
        <div class="video-card__play" aria-hidden="true">
            <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 68 48"
                width="68"
                height="48"
            >
                <rect width="68" height="48" rx="10" fill="rgba(0,0,0,0.72)"
                ></rect>
                <polygon points="26,14 26,34 46,24" fill="#fff"></polygon>
            </svg>
        </div>
    </div>
    <div class="video-card__body">
        <h3 class="video-card__title">{title}</h3>
        <p class="video-card__desc">{description}</p>
    </div>
</a>

<style>
    .video-card {
        display: flex;
        flex-direction: column;
        border-radius: var(--radius-lg);
        overflow: hidden;
        background: var(--surface-soft);
        border: 1px solid var(--border-soft);
        box-shadow: var(--shadow-soft);
        backdrop-filter: blur(18px);
        -webkit-backdrop-filter: blur(18px);
        text-decoration: none;
        color: inherit;
        transition:
            border-color 0.2s ease,
            box-shadow 0.2s ease,
            transform 0.2s ease;
    }

    .video-card:hover {
        color: inherit;
        border-color: var(--border-strong);
        box-shadow: var(--shadow-strong);
        transform: translateY(-2px);
    }

    .video-card__thumb {
        position: relative;
        aspect-ratio: 16 / 9;
        overflow: hidden;
        background: var(--surface-muted);
    }

    .video-card__thumb img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .video-card__play {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: opacity 0.2s ease;
    }

    .video-card:hover .video-card__play {
        opacity: 1;
    }

    .video-card__body {
        padding: 1rem 1.1rem 1.2rem;
        flex: 1;
    }

    .video-card__title {
        font-size: 0.95rem;
        font-weight: 700;
        margin-bottom: 0.35rem;
        line-height: 1.3;
    }

    .video-card__desc {
        font-size: 0.82rem;
        color: var(--text-soft);
        margin: 0;
        line-height: 1.5;
    }
</style>
